# ==========================================================
# 时区配置 (Time Zone Configuration)
# ==========================================================
TIME_ZONE=Asia/Shanghai

# ==========================================================
# 镜像仓库配置 | Docker Image Registry Configuration
# ==========================================================
#
# 镜像源列表 (Available Mirrors):
#   - docker.cnb.cool/seatonjiang/monolith
#   - ghcr.io/seatonjiang
#
# ==========================================================
IMAGE_REGISTRY=docker.cnb.cool/seatonjiang/monolith

# ==========================================================
# Alpine Linux 镜像源配置 (Alpine Linux Mirror Configuration)
# ==========================================================
#
# 镜像源列表 (Available Mirrors):
#   - mirrors.ustc.edu.cn
#   - mirrors.tuna.tsinghua.edu.cn
#   - mirrors.aliyun.com
#   - mirrors.cloud.tencent.com
#
# ==========================================================
ALPINE_MIRROR=mirrors.ustc.edu.cn

# ==========================================================
# Ubuntu 镜像源配置 (Ubuntu Mirror Configuration)
# ==========================================================
#
# 镜像源列表 (Available Mirrors):
#   - mirrors.ustc.edu.cn
#   - mirrors.tuna.tsinghua.edu.cn
#   - mirrors.aliyun.com
#   - mirrors.cloud.tencent.com
#
# ==========================================================
UBUNTU_MIRROR=mirrors.ustc.edu.cn

# ==========================================================
# PHP 配置 (PHP Configuration)
# ==========================================================
#
# 支持版本 (Supported Versions):
#   - 8.1-fpm-alpine
#   - 8.2-fpm-alpine
#   - 8.3-fpm-alpine
#   - 8.4-fpm-alpine
#
# ==========================================================
PHP_VERSION=8.4-fpm-alpine

# ==========================================================
# Openresty 配置 (Openresty Configuration)
# ==========================================================
#
# 支持版本 (Supported Versions):
#   - alpine
#
# 参数说明 (Parameter Description):
#   - OPENRESTY_HTTP_PORT: 定义 OpenResty 监听的 HTTP 端口
#   - OPENRESTY_HTTPS_PORT: 定义 OpenResty 监听的 HTTPS 端口
#
# ==========================================================
OPENRESTY_VERSION=alpine
OPENRESTY_HTTP_PORT=80
OPENRESTY_HTTPS_PORT=443

# ==========================================================
# MariaDB 配置 (MariaDB Configuration)
# ==========================================================
#
# 支持版本 (Supported Versions):
#   - 11.8
#
# 参数说明 (Parameter Description):
#   - MARIADB_DATABASE_NAME: 定义 MariaDB 实例中的​​数据库名称
#
# ==========================================================
MARIADB_VERSION=11.8
MARIADB_DATABASE_NAME=monolith

# ==========================================================
# phpMyAdmin 配置 (phpMyAdmin Configuration)
# ==========================================================
#
# 支持版本 (Supported Versions):
#   - 5.2
#
# 参数说明 (Parameter Description):
#   - PHPMYADMIN_WEB_PORT: Web 访问端口
#   - PHPMYADMIN_UPLOAD_LIMIT: 文件上传大小限制
#
# ==========================================================
PHPMYADMIN_VERSION=5.2
PHPMYADMIN_WEB_PORT=28080
PHPMYADMIN_UPLOAD_LIMIT=128M

# ==========================================================
# Memcached 配置 (Memcached Configuration)
# ==========================================================
#
# 支持版本 (Supported Versions):
#   - 1.6-alpine
#
# ==========================================================
MEMCACHED_VERSION=1.6-alpine

# ==========================================================
# Redis 配置 (Redis Configuration)
# ==========================================================
#
# 支持版本 (Supported Versions):
#   - 8.2-alpine
#
# ==========================================================
REDIS_VERSION=8.2-alpine
