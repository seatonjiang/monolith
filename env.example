#
# 时区配置
#
TIME_ZONE=Asia/Shanghai

#
# Alpine 镜像源配置
#
ALPINE_MIRROR=mirrors.ustc.edu.cn

#
# Ubuntu 镜像源配置
#
UBUNTU_MIRROR=mirrors.ustc.edu.cn

#
# PHP 配置（支持版本请参考链接）
# https://docker.cnb.cool/seatonjiang/monolith/php
#
PHP_VERSION=8.4-fpm-alpine

#
# Openresty 配置（支持版本请参考链接）
# https://docker.cnb.cool/seatonjiang/monolith/openresty
#
OPENRESTY_VERSION=alpine
OPENRESTY_HTTP_PORT=80
OPENRESTY_HTTPS_PORT=443

#
# MariaDB 配置（支持版本请参考链接）
# https://docker.cnb.cool/seatonjiang/monolith/mariadb
#
MARIADB_VERSION=11.8
MARIADB_DATABASE_NAME=monolith

#
# phpMyAdmin 配置（支持版本请参考链接）
# https://docker.cnb.cool/seatonjiang/monolith/phpmyadmin
#
PHPMYADMIN_VERSION=5.2
PHPMYADMIN_WEB_PORT=28080
PHPMYADMIN_UPLOAD_LIMIT=128M

#
# Memcached 配置（支持版本请参考链接）
# https://docker.cnb.cool/seatonjiang/monolith/memcached
#
MEMCACHED_VERSION=1.6-alpine

#
# Redis 配置（支持版本请参考链接）
# https://docker.cnb.cool/seatonjiang/monolith/redis
#
REDIS_VERSION=8.2-alpine
